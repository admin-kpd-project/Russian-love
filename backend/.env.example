# Copy to .env and adjust. Prefix DATING_ for all settings (pydantic-settings).

DATING_DATABASE_URL=postgresql+asyncpg://dating:dating@localhost:5432/dating
DATING_REDIS_URL=redis://localhost:6379/0

DATING_JWT_SECRET=replace-with-long-random-secret-min-32-characters

# --- Amazon S3 (production): leave endpoint empty, use region + virtual addressing ---
# DATING_S3_ENDPOINT_URL=
# DATING_S3_PRESIGN_ENDPOINT_URL=
# DATING_S3_REGION=eu-north-1
# DATING_S3_ADDRESSING_STYLE=virtual
# DATING_S3_BUCKET=your-bucket
# DATING_CDN_PUBLIC_BASE_URL=https://your-bucket.s3.eu-north-1.amazonaws.com
# DATING_S3_ACCESS_KEY=AKIA...
# DATING_S3_SECRET_KEY=...
# (Optional) empty key + secret = IAM role / instance profile
# CORS on the bucket must allow PUT from your web origin + Content-Type.

# --- Yandex Object Storage (S3 API on Yandex Cloud) ---
# Docs: https://yandex.cloud/docs/storage/
# Endpoint: https://storage.yandexcloud.net  path-style: https://storage.yandexcloud.net/<bucket>/<key>
# static access key: https://yandex.cloud/docs/iam/operations/sa-access-key
# CORS: bucket → CORS → allow your site origin, methods GET/PUT/HEAD, allowed headers * or Content-Type
# DATING_S3_YANDEX_OBJECT_STORAGE=true
# DATING_S3_ACCESS_KEY=YCAJ...
# DATING_S3_SECRET_KEY=...
# DATING_S3_BUCKET=your-bucket
# With the flag, defaults apply: endpoint + ru-central1 + CDN base https://storage.yandexcloud.net/<bucket>
# (override DATING_S3_REGION if the bucket is not in ru-central1, e.g. kz1)
# path-style is recommended; set explicitly for stable presigned URLs:
# DATING_S3_ADDRESSING_STYLE=path
# (virtual-hosted: https://<bucket>.storage.yandexcloud.net/<key> — set all URLs manually, flag off)

# --- Local MinIO (optional): see docker-compose minio + Nginx on 8080 ---
DATING_S3_ENDPOINT_URL=http://localhost:9000
DATING_S3_PRESIGN_ENDPOINT_URL=http://localhost:9000
DATING_S3_ADDRESSING_STYLE=path
# When using Nginx in front of MinIO (full stack on :8080) with Vite dev (X-Vite-S3-Proxy):
# DATING_S3_PRESIGN_ENDPOINT_URL=http://localhost:8080
# DATING_S3_NGINX_DEV_GATEWAY_URL=http://localhost:8080
# DATING_CDN_PUBLIC_BASE_URL=http://localhost:8080/s3/dating-media
DATING_S3_ACCESS_KEY=minioadmin
DATING_S3_SECRET_KEY=minioadmin
DATING_S3_BUCKET=dating-media
DATING_CDN_PUBLIC_BASE_URL=http://localhost:9000/dating-media

DATING_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATING_TRUSTED_HOSTS=localhost,127.0.0.1

# --- HTTPS / reverse proxy (production) ---
# Публичный origin сайта (тот же хост, что у Nginx с location /s3/<bucket>/). Presigned PUT и fileUrl.
# DATING_PUBLIC_BASE_URL=https://dev.example.com
# Если TLS на внешнем балансировщике, а X-Forwarded-Proto до API не доходит как https:
# DATING_FORCE_HTTPS_ASSET_URLS=true
# Uvicorn в Docker уже с --proxy-headers; доверие к IP прокси (см. Dockerfile):
# FORWARDED_ALLOW_IPS=*
# CDN и CORS тоже на https:
# DATING_CDN_PUBLIC_BASE_URL=https://dev.example.com/s3/dating-media
# DATING_CORS_ORIGINS=https://dev.example.com
# DATING_TRUSTED_HOSTS=localhost,127.0.0.1,api,nginx,dev.example.com

# --- Production VPS (заход по статическому IP; см. Android network_security_config.xml для cleartext) ---
# DATING_CORS_ORIGINS=http://81.26.181.58:8080
# DATING_TRUSTED_HOSTS=localhost,127.0.0.1,81.26.181.58

# Optional Yandex OAuth
# DATING_YANDEX_CLIENT_ID=
# DATING_YANDEX_CLIENT_SECRET=
# DATING_YANDEX_REDIRECT_URI=http://localhost:8000/api/auth/yandex/callback

# Optional Telegram OAuth
# DATING_TELEGRAM_BOT_USERNAME=
# DATING_TELEGRAM_BOT_TOKEN=

# T-Bank payments
# DATING_TBANK_TERMINAL_KEY=
# DATING_TBANK_PASSWORD=
# DATING_TBANK_WEBHOOK_SECRET=
