<?xml version="1.0" encoding="utf-8"?>
<!-- Разрешён cleartext: в приложении задаётся произвольный base URL (LAN, стенд по IP). -->
<!-- Для прод-API предпочитайте https://… — тогда трафик шифруется независимо от этого флага. -->
<network-security-config>
  <base-config cleartextTrafficPermitted="true">
    <trust-anchors>
      <certificates src="system" />
    </trust-anchors>
  </base-config>
</network-security-config>
